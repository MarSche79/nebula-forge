{
    "$schema": "https://developer.microsoft.com/en-us/json-schemas/teams/v1.23/MicrosoftTeams.schema.json",
    "manifestVersion": "1.23",
    "version": "1.0.0",
    "id": "${{TEAMS_APP_ID}}",
    "developer": {
        "name": "Nebula Forge Station Operations",
        "websiteUrl": "https://nebulaforge.station",
        "privacyUrl": "https://nebulaforge.station/privacy",
        "termsOfUseUrl": "https://nebulaforge.station/terms"
    },
    "icons": {
        "color": "color.png",
        "outline": "outline.png"
    },
    "name": {
        "short": "NF Explorer",
        "full": "Nebula Forge Exploration Navigator"
    },
    "description": {
        "short": "Mission planning, route optimization, and celestial body database for exploration",
        "full": "Nebula Forge Exploration Navigator assists with mission planning, route calculation and optimization, celestial body database queries, and mission status tracking for all Nebula Forge station exploration operations."
    },
    "accentColor": "#2ECC71",
    "composeExtensions": [],
    "copilotAgents": {
        "declarativeAgents": [
            {
                "id": "declarativeAgent",
                "file": "declarativeAgent.json"
            }
        ]
    },
    "permissions": [
        "identity",
        "messageTeamMembers"
    ],
    "validDomains": []
}
