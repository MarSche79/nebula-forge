{
    "$schema": "https://developer.microsoft.com/en-us/json-schemas/teams/v1.23/MicrosoftTeams.schema.json",
    "manifestVersion": "1.23",
    "version": "1.0.0",
    "id": "${{TEAMS_APP_ID}}",
    "developer": {
        "name": "Nebula Forge Station Operations",
        "websiteUrl": "https://nebulaforge.station",
        "privacyUrl": "https://nebulaforge.station/privacy",
        "termsOfUseUrl": "https://nebulaforge.station/terms"
    },
    "icons": {
        "color": "color.png",
        "outline": "outline.png"
    },
    "name": {
        "short": "NF Chief Engineer",
        "full": "Nebula Forge Chief Engineer"
    },
    "description": {
        "short": "Station systems monitoring, repair scheduling, diagnostics, and power grid management.",
        "full": "Nebula Forge Chief Engineer — your AI assistant for space station systems monitoring, repair scheduling and prioritization, running diagnostics on critical systems, and managing the station power grid. Keeps Nebula Forge running at peak operational readiness."
    },
    "accentColor": "#F39C12",
    "composeExtensions": [],
    "copilotAgents": {
        "declarativeAgents": [
            {
                "id": "declarativeAgent",
                "file": "declarativeAgent.json"
            }
        ]
    },
    "permissions": [
        "identity",
        "messageTeamMembers"
    ],
    "validDomains": []
}
