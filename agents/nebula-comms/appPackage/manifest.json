{
    "$schema": "https://developer.microsoft.com/en-us/json-schemas/teams/v1.23/MicrosoftTeams.schema.json",
    "manifestVersion": "1.23",
    "version": "1.0.0",
    "id": "${{TEAMS_APP_ID}}",
    "developer": {
        "name": "Nebula Forge Station Operations",
        "websiteUrl": "https://nebulaforge.station",
        "privacyUrl": "https://nebulaforge.station/privacy",
        "termsOfUseUrl": "https://nebulaforge.station/terms"
    },
    "icons": {
        "color": "color.png",
        "outline": "outline.png"
    },
    "name": {
        "short": "NF Comms Officer",
        "full": "Nebula Forge Communications Officer"
    },
    "description": {
        "short": "Station communications — messaging, broadcasts, signal relay, and deep-space transmissions.",
        "full": "Nebula Forge Communications Officer — your AI assistant for managing all station communications. Handle crew messaging, station-wide broadcasts, signal relay monitoring, deep-space transmission scheduling, and communication logs."
    },
    "accentColor": "#3498DB",
    "composeExtensions": [],
    "copilotAgents": {
        "declarativeAgents": [
            {
                "id": "declarativeAgent",
                "file": "declarativeAgent.json"
            }
        ]
    },
    "permissions": [
        "identity",
        "messageTeamMembers"
    ],
    "validDomains": []
}
