{
    "$schema": "https://developer.microsoft.com/en-us/json-schemas/teams/v1.23/MicrosoftTeams.schema.json",
    "manifestVersion": "1.23",
    "version": "1.0.0",
    "id": "${{TEAMS_APP_ID}}",
    "developer": {
        "name": "Nebula Forge Station Operations",
        "websiteUrl": "https://nebulaforge.station",
        "privacyUrl": "https://nebulaforge.station/privacy",
        "termsOfUseUrl": "https://nebulaforge.station/terms"
    },
    "icons": {
        "color": "color.png",
        "outline": "outline.png"
    },
    "name": {
        "short": "NF Safety Officer",
        "full": "Nebula Forge Safety Officer"
    },
    "description": {
        "short": "Safety & compliance — incident reporting, radiation monitoring, and emergency protocols",
        "full": "Nebula Forge Safety Officer manages incident reporting and tracking, radiation level monitoring, safety audits, and emergency protocol guidance for all Nebula Forge station operations. Crew safety is always the top priority."
    },
    "accentColor": "#E74C3C",
    "composeExtensions": [],
    "copilotAgents": {
        "declarativeAgents": [
            {
                "id": "declarativeAgent",
                "file": "declarativeAgent.json"
            }
        ]
    },
    "permissions": [
        "identity",
        "messageTeamMembers"
    ],
    "validDomains": []
}
