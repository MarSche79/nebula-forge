{
    "$schema": "https://developer.microsoft.com/en-us/json-schemas/teams/v1.23/MicrosoftTeams.schema.json",
    "manifestVersion": "1.23",
    "version": "1.0.0",
    "id": "${{TEAMS_APP_ID}}",
    "developer": {
        "name": "Nebula Forge Station Operations",
        "websiteUrl": "https://nebulaforge.station",
        "privacyUrl": "https://nebulaforge.station/privacy",
        "termsOfUseUrl": "https://nebulaforge.station/terms"
    },
    "icons": {
        "color": "color.png",
        "outline": "outline.png"
    },
    "name": {
        "short": "NF Material Analyst",
        "full": "Nebula Forge Material Analyst"
    },
    "description": {
        "short": "Space material analysis — sample cataloging, composition analysis, and mineral classification",
        "full": "Nebula Forge Material Analyst provides comprehensive space material analysis capabilities including sample cataloging, composition breakdown, mineral classification, comparative material studies, and risk assessment for all samples collected during Nebula Forge station operations."
    },
    "accentColor": "#E67E22",
    "composeExtensions": [],
    "copilotAgents": {
        "declarativeAgents": [
            {
                "id": "declarativeAgent",
                "file": "declarativeAgent.json"
            }
        ]
    },
    "permissions": [
        "identity",
        "messageTeamMembers"
    ],
    "validDomains": []
}
