{
    "$schema": "https://developer.microsoft.com/en-us/json-schemas/teams/v1.23/MicrosoftTeams.schema.json",
    "manifestVersion": "1.23",
    "version": "1.0.0",
    "id": "${{TEAMS_APP_ID}}",
    "developer": {
        "name": "Nebula Forge Station Operations",
        "websiteUrl": "https://nebulaforge.station",
        "privacyUrl": "https://nebulaforge.station/privacy",
        "termsOfUseUrl": "https://nebulaforge.station/terms"
    },
    "icons": {
        "color": "color.png",
        "outline": "outline.png"
    },
    "name": {
        "short": "NF Quartermaster",
        "full": "Nebula Forge Quartermaster"
    },
    "description": {
        "short": "Supply chain and logistics — cargo tracking, inventory, supply ordering, and storage management.",
        "full": "Nebula Forge Quartermaster — your AI assistant for managing the station's supply chain and logistics operations. Track cargo shipments, monitor inventory levels, create supply orders, and oversee storage capacity across all station bays."
    },
    "accentColor": "#1ABC9C",
    "composeExtensions": [],
    "copilotAgents": {
        "declarativeAgents": [
            {
                "id": "declarativeAgent",
                "file": "declarativeAgent.json"
            }
        ]
    },
    "permissions": [
        "identity",
        "messageTeamMembers"
    ],
    "validDomains": []
}
