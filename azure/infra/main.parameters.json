{
  "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentParameters.json#",
  "contentVersion": "1.0.0.0",
  "parameters": {
    "environmentName": {
      "value": "${AZURE_ENV_NAME}"
    },
    "location": {
      "value": "${AZURE_LOCATION}"
    },
    "principalId": {
      "value": "${AZURE_PRINCIPAL_ID=${DEVELOPER_PRINCIPAL_ID=}}"
    },
    "principalName": {
      "value": "${DEVELOPER_PRINCIPAL_NAME=}"
    },
    "principalType": {
      "value": "${DEVELOPER_PRINCIPAL_TYPE=User}"
    },
    "createEntraApp": {
      "value": false
    },
    "authEnabled": {
      "value": "${AUTH_ENABLED=false}"
    },
    "aadClientId": {
      "value": "${AAD_CLIENT_ID=}"
    },
    "aadClientSecret": {
      "value": "${AAD_CLIENT_SECRET=}"
    },
    "customDomainHostnames": {
      "value": "${PORTAL_CUSTOM_HOSTNAMES_JSON=[]}"
    },
    "portalCustomDomains": {
      "value": "${PORTAL_CUSTOM_DOMAINS_JSON=[]}"
    },
    "apiImageName":         { "value": "${SERVICE_API_IMAGE_NAME=}" },
    "portalImageName":      { "value": "${SERVICE_PORTAL_IMAGE_NAME=}" },
    "hrImageName":          { "value": "${SERVICE_HR_IMAGE_NAME=}" },
    "materialsImageName":   { "value": "${SERVICE_MATERIALS_IMAGE_NAME=}" },
    "explorationImageName": { "value": "${SERVICE_EXPLORATION_IMAGE_NAME=}" },
    "scienceImageName":     { "value": "${SERVICE_SCIENCE_IMAGE_NAME=}" },
    "safetyImageName":      { "value": "${SERVICE_SAFETY_IMAGE_NAME=}" },
    "engineeringImageName": { "value": "${SERVICE_ENGINEERING_IMAGE_NAME=}" },
    "logisticsImageName":   { "value": "${SERVICE_LOGISTICS_IMAGE_NAME=}" },
    "commsImageName":       { "value": "${SERVICE_COMMS_IMAGE_NAME=}" },
    "medbayImageName":      { "value": "${SERVICE_MEDBAY_IMAGE_NAME=}" },
    "scribeImageName":      { "value": "${SERVICE_SCRIBE_IMAGE_NAME=}" },
    "heraldImageName":      { "value": "${SERVICE_HERALD_IMAGE_NAME=}" },
    "sentinelImageName":    { "value": "${SERVICE_SENTINEL_IMAGE_NAME=}" },
    "auditorImageName":     { "value": "${SERVICE_AUDITOR_IMAGE_NAME=}" },
    "whispererImageName":   { "value": "${SERVICE_WHISPERER_IMAGE_NAME=}" },
    "agentTickImageName":   { "value": "${SERVICE_AGENT_TICK_IMAGE_NAME=}" },
    "gptImageName":         { "value": "${SERVICE_GPT_IMAGE_NAME=}" },
    "gptAppClientId":       { "value": "${GPT_APP_CLIENT_ID=}" },
    "gptAppClientSecret":   { "value": "${GPT_APP_CLIENT_SECRET=}" },
    "paSaveDocWebhook":     { "value": "${PA_SAVE_DOC_WEBHOOK=}" },
    "nebulaGptSharepointSiteUrl": { "value": "${NEBULAGPT_SHAREPOINT_SITE_URL=https://mngenvmcap805678.sharepoint.com/sites/NebulaForgeAgentSharePoint}" },
    "paTeamsWebhook":       { "value": "${PA_TEAMS_WEBHOOK=}" },
    "paCcWebhook":          { "value": "${PA_CC_WEBHOOK=}" },
    "paSpCreateWebhook":    { "value": "${PA_SP_CREATE_WEBHOOK=}" },
    "paSpLabelWebhook":     { "value": "${PA_SP_LABEL_WEBHOOK=}" },
    "deployGpt4o":          { "value": "${DEPLOY_GPT_4O=true}" },
    "agentTickCron":        { "value": "${AGENT_TICK_CRON=*/30 * * * *}" },
    "proxySharedSecret":    { "value": "${PROXY_SHARED_SECRET=}" }
  }
}
